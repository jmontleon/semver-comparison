    content: <!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PatternFly 5вҶ’6 Migration Comparison Report</title>
<style>
:root {
  --bg: #0d1117;
  --surface: #161b22;
  --surface2: #1c2129;
  --border: #30363d;
  --text: #e6edf3;
  --text-muted: #8b949e;
  --accent: #58a6ff;
  --green: #3fb950;
  --red: #f85149;
  --orange: #d29922;
  --purple: #bc8cff;
  --teal: #39d2c0;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  padding: 2rem 1rem;
}

.container { max-width: 1400px; margin: 0 auto; }

h1 { font-size: 2rem; margin-bottom: 0.5rem; }
h2 { font-size: 1.5rem; margin: 2rem 0 1rem; color: var(--accent); border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
h3 { font-size: 1.15rem; margin: 1.5rem 0 0.75rem; color: var(--text); }
h4 { font-size: 1rem; margin: 1rem 0 0.5rem; color: var(--text-muted); }

a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }

.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.25rem;
  margin-bottom: 1rem;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
  gap: 1rem;
  margin-bottom: 1.5rem;
}

@media (max-width: 900px) {
  .card-grid { grid-template-columns: 1fr; }
}

.verdict-banner {
  border: 2px solid var(--green);
  background: linear-gradient(135deg, rgba(63, 185, 80, 0.08), rgba(63, 185, 80, 0.02));
  border-radius: 12px;
  padding: 2rem;
  margin-bottom: 2rem;
}

.verdict-banner h1 { color: var(--green); font-size: 1.75rem; }
.verdict-banner .subtitle { color: var(--text-muted); font-size: 1rem; margin-bottom: 1rem; }

.score-cards { display: flex; gap: 1.5rem; margin: 1.5rem 0; flex-wrap: wrap; }
.score-card {
  flex: 1;
  min-width: 250px;
  padding: 1.25rem 1.5rem;
  border-radius: 10px;
  text-align: center;
}
.score-card.winner {
  background: rgba(63, 185, 80, 0.12);
  border: 2px solid var(--green);
}
.score-card.loser {
  background: rgba(248, 81, 73, 0.08);
  border: 2px solid var(--red);
}
.score-card .score-value { font-size: 2.5rem; font-weight: 800; }
.score-card .score-label { font-size: 0.85rem; color: var(--text-muted); margin-top: 0.25rem; }
.score-card .branch-name { font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; word-break: break-all; }
.score-card.winner .score-value { color: var(--green); }
.score-card.loser .score-value { color: var(--red); }

.reasons { margin-top: 1rem; }
.reasons li { margin-left: 1.5rem; margin-bottom: 0.35rem; color: var(--text); }
.reasons li::marker { color: var(--green); }

/* Table of contents */
.toc { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem 1.5rem; margin-bottom: 2rem; }
.toc ol { padding-left: 1.5rem; }
.toc li { margin-bottom: 0.35rem; }

/* Tables */
table {
  width: 100%;
  border-collapse: collapse;
  margin: 1rem 0;
  font-size: 0.9rem;
}
th, td {
  padding: 0.6rem 0.75rem;
  border: 1px solid var(--border);
  text-align: left;
}
th {
  background: var(--surface2);
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  font-size: 0.75rem;
  letter-spacing: 0.03em;
}
td { background: var(--surface); }
tr:hover td { background: var(--surface2); }

.badge {
  display: inline-block;
  padding: 0.15rem 0.6rem;
  border-radius: 12px;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
}
.badge-green { background: rgba(63,185,80,0.2); color: var(--green); }
.badge-red { background: rgba(248,81,73,0.15); color: var(--red); }
.badge-orange { background: rgba(210,153,34,0.2); color: var(--orange); }
.badge-purple { background: rgba(188,140,255,0.2); color: var(--purple); }
.badge-teal { background: rgba(57,210,192,0.2); color: var(--teal); }
.badge-muted { background: rgba(139,148,158,0.15); color: var(--text-muted); }

/* Metric card coloring */
.metric { display: flex; justify-content: space-between; padding: 0.4rem 0; border-bottom: 1px solid var(--border); }
.metric:last-child { border-bottom: none; }
.metric-label { color: var(--text-muted); font-size: 0.85rem; }
.metric-value { font-weight: 600; font-size: 0.9rem; }
.metric-value.good { color: var(--green); }
.metric-value.bad { color: var(--red); }
.metric-value.warn { color: var(--orange); }
.metric-value.neutral { color: var(--text); }

/* Horizontal bar chart */
.bar-chart { margin: 1rem 0; }
.bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 0.75rem;
  gap: 0.75rem;
}
.bar-label {
  min-width: 220px;
  font-size: 0.85rem;
  color: var(--text-muted);
  text-align: right;
  word-break: break-all;
}
.bar-track {
  flex: 1;
  height: 28px;
  background: var(--surface2);
  border-radius: 6px;
  overflow: hidden;
  position: relative;
}
.bar-fill {
  height: 100%;
  border-radius: 6px;
  display: flex;
  align-items: center;
  padding-left: 8px;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--bg);
  transition: width 0.5s ease;
}
.bar-fill.green { background: var(--green); }
.bar-fill.red { background: var(--red); }
.bar-fill.orange { background: var(--orange); }
.bar-fill.purple { background: var(--purple); }

/* Progress bar segments */
.progress-bar {
  display: flex;
  height: 24px;
  border-radius: 6px;
  overflow: hidden;
  margin: 0.5rem 0;
}
.progress-segment {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  font-weight: 600;
  color: var(--bg);
}

/* Details/collapsible */
details {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  margin-bottom: 0.75rem;
}
details[open] { border-color: var(--accent); }
summary {
  cursor: pointer;
  padding: 0.85rem 1rem;
  font-weight: 600;
  list-style: none;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
summary::before { content: 'в–ё'; color: var(--accent); transition: transform 0.2s; }
details[open] > summary::before { transform: rotate(90deg); }
summary::-webkit-details-marker { display: none; }
.details-content { padding: 0 1rem 1rem; }

/* Code blocks */
pre {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 1rem;
  overflow-x: auto;
  font-size: 0.82rem;
  line-height: 1.5;
  margin: 0.75rem 0;
}
code { font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace; }
.code-add { color: var(--green); }
.code-del { color: var(--red); }

/* Winner badge in tables */
.winner-cell { background: rgba(63,185,80,0.08) !important; }

.section-anchor { scroll-margin-top: 2rem; }

.footnote { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.5rem; }

.risk-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1rem;
}

.divider { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
</style>
</head>
