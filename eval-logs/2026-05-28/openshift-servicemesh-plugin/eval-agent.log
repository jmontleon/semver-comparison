    content: <!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PatternFly 5вҶ’6 Migration Comparison Report</title>
<style>
:root {
  --bg: #0d1117;
  --surface: #161b22;
  --surface2: #1c2129;
  --border: #30363d;
  --text: #e6edf3;
  --text-muted: #8b949e;
  --accent: #58a6ff;
  --green: #3fb950;
  --red: #f85149;
  --orange: #d29922;
  --purple: #bc8cff;
  --teal: #39d2c0;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  padding: 2rem 1rem;
}
.container { max-width: 1400px; margin: 0 auto; }
h1 { font-size: 2rem; margin-bottom: 0.5rem; }
h2 { font-size: 1.5rem; margin: 2rem 0 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
h3 { font-size: 1.2rem; margin: 1.5rem 0 0.75rem; color: var(--accent); }
h4 { font-size: 1.05rem; margin: 1rem 0 0.5rem; }
a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }
p { margin-bottom: 0.75rem; }
code {
  background: var(--surface2);
  padding: 0.15em 0.4em;
  border-radius: 4px;
  font-size: 0.9em;
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
}
pre {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1rem;
  overflow-x: auto;
  font-size: 0.85rem;
  margin: 0.75rem 0;
  line-height: 1.5;
}
pre code { background: none; padding: 0; }
table {
  width: 100%;
  border-collapse: collapse;
  margin: 1rem 0;
  font-size: 0.9rem;
}
th, td {
  padding: 0.6rem 0.8rem;
  border: 1px solid var(--border);
  text-align: left;
  vertical-align: top;
}
th { background: var(--surface2); font-weight: 600; white-space: nowrap; }
tr:nth-child(even) td { background: rgba(22, 27, 34, 0.5); }

/* Cards */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.25rem;
  margin-bottom: 1rem;
}
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
  gap: 1rem;
  margin: 1rem 0;
}
@media (max-width: 900px) {
  .card-grid { grid-template-columns: 1fr; }
}

/* Verdict banner */
.verdict {
  border: 2px solid var(--green);
  background: rgba(63, 185, 80, 0.06);
  border-radius: 12px;
  padding: 1.5rem 2rem;
  margin-bottom: 2rem;
}
.verdict h2 { border: none; margin: 0 0 0.75rem; padding: 0; font-size: 1.6rem; }
.verdict .winner-name { color: var(--green); font-size: 1.8rem; font-weight: 700; }
.verdict ul { margin-left: 1.5rem; margin-top: 0.5rem; }
.verdict li { margin-bottom: 0.3rem; }

/* Score cards */
.score-cards {
  display: flex;
  gap: 1rem;
  margin: 1rem 0;
  flex-wrap: wrap;
}
.score-card {
  flex: 1;
  min-width: 200px;
  border-radius: 10px;
  padding: 1rem 1.25rem;
  text-align: center;
}
.score-card.winner { background: rgba(63, 185, 80, 0.1); border: 2px solid var(--green); }
.score-card.loser { background: rgba(248, 81, 73, 0.1); border: 2px solid var(--red); }
.score-card .score-value { font-size: 2.5rem; font-weight: 700; line-height: 1.2; }
.score-card.winner .score-value { color: var(--green); }
.score-card.loser .score-value { color: var(--red); }
.score-card .score-label { font-size: 0.85rem; color: var(--text-muted); margin-top: 0.25rem; }
.score-card .branch-name { font-weight: 600; font-size: 1.1rem; margin-bottom: 0.25rem; }

/* Badges */
.badge {
  display: inline-block;
  padding: 0.15em 0.6em;
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 600;
  white-space: nowrap;
}
.badge-green { background: rgba(63,185,80,0.2); color: var(--green); border: 1px solid rgba(63,185,80,0.3); }
.badge-red { background: rgba(248,81,73,0.2); color: var(--red); border: 1px solid rgba(248,81,73,0.3); }
.badge-orange { background: rgba(210,153,34,0.2); color: var(--orange); border: 1px solid rgba(210,153,34,0.3); }
.badge-purple { background: rgba(188,140,255,0.2); color: var(--purple); border: 1px solid rgba(188,140,255,0.3); }
.badge-teal { background: rgba(57,210,192,0.2); color: var(--teal); border: 1px solid rgba(57,210,192,0.3); }

/* Bar charts */
.bar-chart { margin: 1rem 0; }
.bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 0.5rem;
  gap: 0.75rem;
}
.bar-label { min-width: 200px; font-size: 0.85rem; text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.bar-track { flex: 1; background: var(--surface2); border-radius: 6px; height: 28px; position: relative; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 6px; display: flex; align-items: center; padding: 0 0.6rem; font-size: 0.8rem; font-weight: 600; min-width: fit-content; transition: width 0.3s; }
.bar-fill.green { background: rgba(63,185,80,0.35); color: var(--green); }
.bar-fill.red { background: rgba(248,81,73,0.35); color: var(--red); }
.bar-fill.orange { background: rgba(210,153,34,0.35); color: var(--orange); }
.bar-fill.purple { background: rgba(188,140,255,0.35); color: var(--purple); }
.bar-fill.teal { background: rgba(57,210,192,0.35); color: var(--teal); }

/* Progress bar */
.progress-bar { width: 100%; height: 24px; background: var(--surface2); border-radius: 6px; overflow: hidden; display: flex; margin: 0.5rem 0; }
.progress-segment { height: 100%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 600; }

/* Details/collapse */
details { margin: 0.75rem 0; }
details summary {
  cursor: pointer;
  padding: 0.75rem 1rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
details summary:hover { background: var(--surface2); }
details[open] summary { border-radius: 8px 8px 0 0; border-bottom: none; }
details .detail-content {
  padding: 1rem;
  border: 1px solid var(--border);
  border-top: none;
  border-radius: 0 0 8px 8px;
  background: var(--surface);
}

/* TOC */
.toc {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.25rem;
  margin: 1.5rem 0;
}
.toc ol { margin-left: 1.5rem; }
.toc li { margin-bottom: 0.35rem; font-size: 0.95rem; }

/* Metric highlights */
.metric { display: flex; justify-content: space-between; padding: 0.35rem 0; border-bottom: 1px solid var(--border); }
.metric:last-child { border-bottom: none; }
.metric-label { color: var(--text-muted); font-size: 0.85rem; }
.metric-value { font-weight: 600; font-size: 0.9rem; }
.metric-value.good { color: var(--green); }
.metric-value.bad { color: var(--red); }
.metric-value.warn { color: var(--orange); }
.metric-value.neutral { color: var(--text); }

/* Diff colors */
.diff-add { color: var(--green); }
.diff-del { color: var(--red); }

/* Winner indicator */
.winner-tag { 
  background: rgba(63,185,80,0.15);
  color: var(--green);
  border: 1px solid rgba(63,185,80,0.3);
  padding: 0.2em 0.6em;
  border-radius: 6px;
  font-size: 0.8rem;
  font-weight: 600;
  margin-left: 0.5rem;
}

.footer {
  margin-top: 3rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
  color: var(--text-muted);
  font-size: 0.85rem;
}
.footer a { color: var(--accent); }
</style>
</head>
