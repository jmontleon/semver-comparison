    command: curl -sL "https://www.patternfly.org/get-started/upgrade/release-notes" 2>/dev/null | python3 -c "
import sys, re
html = sys.stdin.read()
# Extract text content from the release notes table
# Find all table rows
rows = re.findall(r'<tr[^>]*class=\"pf-v6-c-table__tr\"[^>]*>(.*?)</tr>', html, re.DOTALL)
for row in rows[:200]:
    cells = re.findall(r'<td[^>]*>(.*?)</td>', row, re.DOTALL)
    if cells:
        # Clean HTML tags
        clean_cells = []
        for cell in cells:
            text = re.sub(r'<[^>]+>', '', cell).strip()
            text = re.sub(r'\s+', ' ', text)
            clean_cells.append(text)
        if any(clean_cells):
            print(' | '.join(clean_cells))
" 2>/dev/null


