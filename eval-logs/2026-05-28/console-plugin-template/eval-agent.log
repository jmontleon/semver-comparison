      </tr>
      <tr>
        <td>pf-v5 references</td>
        <td><span class="badge badge-green">ZERO ✅</span></td>
        <td>Full-text search for "pf-v5" across all source files: 0 matches</td>
      </tr>
    </table>

    <h4>Source Code (ExamplePage.tsx on main — already PF6)</h4>
    <pre><code>import { Content, PageSection } from '@patternfly/react-core';  <span class="diff-add">// ✅ PF6 Content component</span>
import { CheckCircleIcon } from '@patternfly/react-icons';       <span class="diff-add">// ✅ PF6 icons</span>

// ...
&lt;PageSection&gt;                                                   <span class="diff-add">// ✅ PageSection still valid in PF6</span>
  &lt;Content component="p"&gt;                                       <span class="diff-add">// ✅ PF6 Content (replaces PF5 Text)</span>
