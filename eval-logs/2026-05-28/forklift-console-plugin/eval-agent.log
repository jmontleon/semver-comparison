from html.parser import HTMLParser
import sys

class TagChecker(HTMLParser):
    def __init__(self):
        super().__init__()
        self.stack = []
        self.void_elements = {'br', 'hr', 'img', 'input', 'meta', 'link', 'area', 'base', 'col', 'embed', 'source', 'track', 'wbr'}
    def handle_starttag(self, tag, attrs):
        if tag not in self.void_elements:
            self.stack.append(tag)
    def handle_endtag(self, tag):
        if tag not in self.void_elements:
            if self.stack and self.stack[-1] == tag:
                self.stack.pop()
            else:
                print(f'Mismatch: closing </{tag}> but expected </{self.stack[-1] if self.stack else \"nothing\"}> at approx position')

with open('pf-migration-comparison-report.html') as f:
    content = f.read()
checker = TagChecker()
checker.feed(content)
if checker.stack:
    print(f'Unclosed tags: {checker.stack}')
else:
    print('HTML structure looks valid - all tags properly closed')
print(f'File size: {len(content):,} bytes')
