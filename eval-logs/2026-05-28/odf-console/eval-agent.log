<div class="verdict-banner" id="verdict">
  <h1>ЁЯПЖ Winner: semver/goose/053126-1221</h1>
  <div class="subtitle">PatternFly 5 тЖТ 6 Migration Comparison &mdash; Generated 2026-05-31</div>
  <div class="score-cards">
    <div class="score-card loser">
      <div class="name">pf-codemods-053126-1450</div>
