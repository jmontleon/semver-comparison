<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PatternFly 5тЖТ6 Migration Comparison Report</title>
<style>
:root {
  --bg: #0d1117;
  --surface: #161b22;
  --surface2: #1c2129;
  --border: #30363d;
  --text: #e6edf3;
  --text-muted: #8b949e;
  --accent: #58a6ff;
  --green: #3fb950;
  --red: #f85149;
  --orange: #d29922;
  --purple: #bc8cff;
  --teal: #39d2c0;
}
*, *::before, *::after { box-sizing: border-box; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  background: var(--bg);
  color: var(--text);
  margin: 0;
  padding: 2rem 1rem;
  line-height: 1.6;
}
.container { max-width: 1400px; margin: 0 auto; }
h1 { font-size: 2rem; margin-bottom: 0.5rem; }
h2 { font-size: 1.5rem; color: var(--accent); margin-top: 2.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
h3 { font-size: 1.2rem; color: var(--purple); margin-top: 1.5rem; }
a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }
code {
  background: var(--surface2);
  padding: 0.15em 0.4em;
  border-radius: 4px;
  font-size: 0.9em;
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
}
pre {
  background: var(--surface2);
  padding: 1rem;
  border-radius: 8px;
  overflow-x: auto;
  font-size: 0.85em;
  border: 1px solid var(--border);
}
pre code { background: none; padding: 0; }

/* Cards */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.5rem;
  margin-bottom: 1rem;
}
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
  gap: 1rem;
}
@media (max-width: 900px) {
  .card-grid { grid-template-columns: 1fr; }
}

/* Verdict banner */
.verdict-banner {
  background: var(--surface);
  border: 2px solid var(--green);
  border-radius: 12px;
  padding: 2rem;
  margin-bottom: 2rem;
  text-align: center;
}
.verdict-banner h1 { color: var(--green); font-size: 1.8rem; }
.verdict-banner .subtitle { color: var(--text-muted); font-size: 1.1rem; margin-bottom: 1.5rem; }
.score-cards {
  display: flex;
  justify-content: center;
  gap: 2rem;
  flex-wrap: wrap;
  margin: 1.5rem 0;
}
.score-card {
  background: var(--surface2);
  border-radius: 10px;
  padding: 1.5rem 2.5rem;
  text-align: center;
  min-width: 220px;
}
.score-card.winner { border: 2px solid var(--green); }
.score-card.loser { border: 2px solid var(--red); }
.score-card .name { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 0.5rem; }
.score-card .score { font-size: 3rem; font-weight: 700; }
.score-card.winner .score { color: var(--green); }
.score-card.loser .score { color: var(--red); }
.score-card .label { font-size: 0.8rem; color: var(--text-muted); }

.verdict-reasons {
  text-align: left;
  max-width: 700px;
  margin: 1.5rem auto 0;
}
.verdict-reasons li {
  margin-bottom: 0.5rem;
  color: var(--text);
}

/* TOC */
.toc {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.5rem 2rem;
  margin-bottom: 2rem;
}
.toc ol { margin: 0; padding-left: 1.5rem; }
.toc li { margin-bottom: 0.3rem; }

/* Tables */
table {
  width: 100%;
  border-collapse: collapse;
  margin: 1rem 0;
  font-size: 0.9rem;
}
th, td {
  padding: 0.6rem 0.8rem;
  border: 1px solid var(--border);
  text-align: left;
}
th {
  background: var(--surface2);
  color: var(--accent);
  font-weight: 600;
}
td { background: var(--surface); }
tr:hover td { background: var(--surface2); }

/* Badges */
.badge {
  display: inline-block;
  padding: 0.15em 0.6em;
  border-radius: 12px;
  font-size: 0.8em;
  font-weight: 600;
}
.badge-green { background: rgba(63,185,80,0.15); color: var(--green); border: 1px solid rgba(63,185,80,0.3); }
.badge-red { background: rgba(248,81,73,0.15); color: var(--red); border: 1px solid rgba(248,81,73,0.3); }
.badge-orange { background: rgba(210,153,34,0.15); color: var(--orange); border: 1px solid rgba(210,153,34,0.3); }
.badge-purple { background: rgba(188,140,255,0.15); color: var(--purple); border: 1px solid rgba(188,140,255,0.3); }
.badge-teal { background: rgba(57,210,192,0.15); color: var(--teal); border: 1px solid rgba(57,210,192,0.3); }

/* Details/collapsible */
details {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  margin-bottom: 0.75rem;
}
details summary {
  padding: 0.8rem 1.2rem;
  cursor: pointer;
  font-weight: 600;
  color: var(--accent);
  user-select: none;
}
details summary:hover { color: var(--purple); }
details[open] summary { border-bottom: 1px solid var(--border); }
details .detail-body { padding: 1.2rem; }

/* Bars */
.bar-chart { margin: 1rem 0; }
.bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 0.5rem;
}
.bar-label {
  width: 220px;
  font-size: 0.85rem;
  color: var(--text-muted);
  flex-shrink: 0;
}
.bar-track {
  flex: 1;
  height: 24px;
  background: var(--surface2);
  border-radius: 4px;
  overflow: hidden;
  position: relative;
}
.bar-fill {
  height: 100%;
  border-radius: 4px;
  display: flex;
  align-items: center;
  padding-left: 8px;
  font-size: 0.75rem;
  font-weight: 600;
  color: #fff;
  transition: width 0.3s;
}
.bar-fill.green { background: var(--green); }
.bar-fill.red { background: var(--red); }
.bar-fill.orange { background: var(--orange); }
.bar-fill.purple { background: var(--purple); }
.bar-fill.teal { background: var(--teal); }

/* Progress bar */
.progress-bar {
  width: 100%;
  height: 28px;
  background: var(--surface2);
  border-radius: 6px;
  overflow: hidden;
  display: flex;
}
.progress-segment {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 600;
  color: #fff;
}
.progress-segment.green { background: var(--green); }
.progress-segment.orange { background: var(--orange); }
.progress-segment.red { background: var(--red); }

/* Metric cards */
.metric {
  display: flex;
  justify-content: space-between;
  padding: 0.5rem 0;
  border-bottom: 1px solid var(--border);
}
.metric:last-child { border-bottom: none; }
.metric-label { color: var(--text-muted); font-size: 0.85rem; }
.metric-value { font-weight: 600; }

/* Winner highlight */
.winner-text { color: var(--green); font-weight: 700; }
.loser-text { color: var(--red); }

.footer {
  margin-top: 3rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
  color: var(--text-muted);
  font-size: 0.85rem;
  text-align: center;
}

.highlight-box {
  background: rgba(248,81,73,0.08);
  border-left: 3px solid var(--red);
  padding: 0.8rem 1rem;
  margin: 0.5rem 0;
  border-radius: 0 6px 6px 0;
}
.highlight-box.green {
  background: rgba(63,185,80,0.08);
  border-left-color: var(--green);
}
.highlight-box.orange {
  background: rgba(210,153,34,0.08);
  border-left-color: var(--orange);
}
</style>
</head>
