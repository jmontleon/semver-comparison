  --accent: #58a6ff;
  --green: #3fb950;
  --red: #f85149;
  --orange: #d29922;
  --purple: #bc8cff;
  --teal: #39d2c0;
}
*, *::before, *::after { box-sizing: border-box; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
  margin: 0;
  padding: 0;
  line-height: 1.6;
}
.container { max-width: 1400px; margin: 0 auto; padding: 24px 20px; }

/* Typography */
h1 { font-size: 2rem; margin-bottom: 8px; }
h2 { font-size: 1.5rem; color: var(--accent); margin-top: 40px; margin-bottom: 16px; border-bottom: 1px solid var(--border); padding-bottom: 8px; }
h3 { font-size: 1.2rem; margin-top: 24px; margin-bottom: 12px; }
h4 { font-size: 1rem; margin-top: 16px; margin-bottom: 8px; color: var(--text-muted); }
a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }

/* Cards */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 20px;
  margin-bottom: 16px;
}
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
  gap: 16px;
  margin-bottom: 16px;
}
@media (max-width: 900px) {
  .card-grid { grid-template-columns: 1fr; }
}

/* Verdict Banner */
.verdict-banner {
  background: var(--surface);
  border: 2px solid var(--green);
  border-radius: 12px;
  padding: 28px;
  margin-bottom: 24px;
  position: relative;
}
.verdict-banner.negative { border-color: var(--orange); }
.verdict-title {
  font-size: 1.6rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 12px;
}
.verdict-subtitle { color: var(--text-muted); font-size: 0.95rem; margin-top: 4px; }
.score-cards {
  display: flex;
  gap: 16px;
  margin-top: 20px;
  flex-wrap: wrap;
}
.score-card {
  background: var(--surface2);
  border-radius: 8px;
  padding: 16px 24px;
  text-align: center;
  min-width: 200px;
  border: 2px solid var(--border);
}
.score-card.winner { border-color: var(--green); }
.score-card.loser { border-color: var(--red); }
.score-card .score-value {
  font-size: 2.5rem;
  font-weight: 800;
  line-height: 1;
}
.score-card .score-label {
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-top: 4px;
}
.score-card .branch-name {
  font-size: 0.95rem;
  font-weight: 600;
  margin-bottom: 8px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Badges */
.badge {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 12px;
  font-size: 0.78rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.badge-green { background: rgba(63,185,80,0.15); color: var(--green); border: 1px solid rgba(63,185,80,0.3); }
.badge-red { background: rgba(248,81,73,0.15); color: var(--red); border: 1px solid rgba(248,81,73,0.3); }
.badge-orange { background: rgba(210,153,34,0.15); color: var(--orange); border: 1px solid rgba(210,153,34,0.3); }
.badge-purple { background: rgba(188,140,255,0.15); color: var(--purple); border: 1px solid rgba(188,140,255,0.3); }
.badge-teal { background: rgba(57,210,192,0.15); color: var(--teal); border: 1px solid rgba(57,210,192,0.3); }

/* Tables */
table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 16px;
  font-size: 0.9rem;
}
th, td {
  padding: 10px 14px;
  text-align: left;
  border-bottom: 1px solid var(--border);
}
th {
  background: var(--surface2);
  color: var(--text-muted);
  font-weight: 600;
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  position: sticky;
  top: 0;
}
tr:hover { background: rgba(88,166,255,0.04); }
td.winner-cell { color: var(--green); font-weight: 600; }
td.loser-cell { color: var(--red); }
.total-row td { font-weight: 700; border-top: 2px solid var(--accent); font-size: 1rem; }

/* Code blocks */
pre {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 14px;
  overflow-x: auto;
  font-size: 0.82rem;
  line-height: 1.5;
  margin: 8px 0 16px;
}
code {
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  font-size: 0.85em;
  background: var(--surface2);
  padding: 2px 6px;
  border-radius: 3px;
}
pre code { background: none; padding: 0; }
.code-add { color: var(--green); }
.code-del { color: var(--red); }

/* Details / Collapsible */
details {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  margin-bottom: 12px;
}
details[open] { border-color: var(--accent); }
summary {
  padding: 14px 20px;
  cursor: pointer;
  font-weight: 600;
  font-size: 0.95rem;
  user-select: none;
  display: flex;
  align-items: center;
  gap: 10px;
}
summary:hover { background: rgba(88,166,255,0.06); }
summary::marker { color: var(--accent); }
.details-body { padding: 0 20px 20px; }

/* Bar chart */
.bar-chart { margin: 16px 0; }
.bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
  gap: 12px;
}
.bar-label {
  min-width: 240px;
  font-size: 0.85rem;
  text-align: right;
  color: var(--text-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.bar-track {
  flex: 1;
  background: var(--surface2);
  border-radius: 4px;
  height: 24px;
  position: relative;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  border-radius: 4px;
  display: flex;
  align-items: center;
  padding-left: 8px;
  font-size: 0.78rem;
  font-weight: 600;
  color: #fff;
  min-width: 30px;
  transition: width 0.4s ease;
}
.bar-fill.red { background: var(--red); }
.bar-fill.orange { background: var(--orange); }
.bar-fill.green { background: var(--green); }
.bar-fill.purple { background: var(--purple); }
.bar-fill.teal { background: var(--teal); }

/* Progress bar */
.progress-bar {
  width: 100%;
  height: 28px;
  background: var(--surface2);
  border-radius: 6px;
  overflow: hidden;
  display: flex;
  margin: 8px 0 16px;
}
.progress-segment {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 600;
  color: #fff;
}

/* TOC */
.toc {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 20px 28px;
  margin-bottom: 24px;
}
.toc ol { margin: 0; padding-left: 20px; }
.toc li { margin: 6px 0; }
.toc a { font-size: 0.95rem; }

/* Metric card */
.metric { margin-bottom: 12px; }
.metric-label { font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.metric-value { font-size: 1.3rem; font-weight: 700; }
.metric-value.green { color: var(--green); }
.metric-value.red { color: var(--red); }
.metric-value.orange { color: var(--orange); }

/* Key reasons */
.key-reasons { margin-top: 16px; }
.key-reasons li {
  margin: 8px 0;
  padding-left: 4px;
  list-style: none;
  position: relative;
}
.key-reasons li::before {
  content: '→';
  position: absolute;
  left: -18px;
  color: var(--accent);
}

/* Footer */
.footer {
  margin-top: 48px;
  padding: 24px;
  border-top: 1px solid var(--border);
  text-align: center;
  color: var(--text-muted);
  font-size: 0.85rem;
}
.footer a { margin: 0 12px; }

/* Risk grid */
.risk-metric {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
}
.risk-metric:last-child { border-bottom: none; }

/* Comparison table in details */
.comparison-mini { margin: 12px 0; }
.comparison-mini th { font-size: 0.75rem; }
.comparison-mini td { font-size: 0.85rem; }

.winner-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(63,185,80,0.1);
  border: 1px solid rgba(63,185,80,0.3);
  color: var(--green);
  padding: 4px 12px;
  border-radius: 6px;
  font-size: 0.85rem;
  font-weight: 600;
  margin: 8px 0;
}
.loser-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(248,81,73,0.1);
  border: 1px solid rgba(248,81,73,0.3);
  color: var(--red);
  padding: 4px 12px;
  border-radius: 6px;
  font-size: 0.85rem;
  font-weight: 600;
  margin: 8px 0;
}
.tie-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(210,153,34,0.1);
  border: 1px solid rgba(210,153,34,0.3);
  color: var(--orange);
  padding: 4px 12px;
  border-radius: 6px;
  font-size: 0.85rem;
  font-weight: 600;
  margin: 8px 0;
}

.highlight-box {
  background: rgba(248,81,73,0.08);
  border-left: 3px solid var(--red);
  padding: 12px 16px;
  margin: 12px 0;
  border-radius: 0 6px 6px 0;
  font-size: 0.9rem;
}
.highlight-box.warn {
  background: rgba(210,153,34,0.08);
  border-left-color: var(--orange);
}
.highlight-box.info {
  background: rgba(88,166,255,0.08);
  border-left-color: var(--accent);
}
.highlight-box.ok {
  background: rgba(63,185,80,0.08);
  border-left-color: var(--green);
}
</style>
</head>
<body>
<div class="container">

<!-- ======== 1. VERDICT BANNER ======== -->
<section id="verdict">
<div class="verdict-banner negative">
  <div class="verdict-title">⚠️ Winner: pf-codemods — by narrow margin (both branches are problematic)</div>
  <div class="verdict-subtitle">PatternFly 5 → 6 Migration Comparison Report &middot; Generated 2026-05-31 &middot; Base branch: <code>main</code></div>

  <div class="score-cards">
    <div class="score-card winner">
      <div class="branch-name">pf-codemods-053126-1055</div>
      <div class="score-value" style="color: var(--green);">38</div>
      <div class="score-label">/ 70 points</div>
    </div>
    <div class="score-card loser">
      <div class="branch-name">semver/goose/053126-1035</div>
      <div class="score-value" style="color: var(--red);">25</div>
      <div class="score-label">/ 70 points</div>
    </div>
  </div>

  <ul class="key-reasons">
    <li><strong>Critical finding:</strong> The base branch <code>main</code> is already on PF6 packages (<code>~6.4.0</code>), builds clean with 0 TypeScript errors, and already uses the <em>new</em> composable Modal API. Neither migration branch improves the build — both introduce 40 TypeScript errors.</li>
    <li><strong>pf-codemods wins</strong> because it makes fewer mistakes: its changes are focused (PageSection <code>hasBodyWrapper</code> additions are valid PF6 fixes) and it doesn't break package.json. Its Modal→deprecated move is wrong but less damaging than Branch 2's errors.</li>
    <li><strong>semver/goose loses</strong> because it introduces <strong>runtime-crashing bugs</strong> (StackItem/SplitItem <code>component</code> prop misuse), <strong>breaks the webpack build</strong> via unnecessary package version changes (React 17→18, react-router 5→7, react-i18next 11→2.2.3 downgrade), and makes many incorrect API assumptions.</li>
    <li><strong>Neither branch is merge-ready.</strong> Both need significant additional work. The base branch is actually in a better state than either migration branch.</li>
  </ul>
</div>
</section>

