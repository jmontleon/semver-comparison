    content: <!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PatternFly 5→6 Migration Comparison Report</title>
<style>
:root {
  --bg: #0d1117;
  --surface: #161b22;
  --surface2: #1c2129;
  --border: #30363d;
  --text: #e6edf3;
  --text-muted: #8b949e;
  --accent: #58a6ff;
  --green: #3fb950;
  --red: #f85149;
  --orange: #d29922;
  --purple: #bc8cff;
  --teal: #39d2c0;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans', Helvetica, Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  padding: 2rem 1rem;
}

.container { max-width: 1400px; margin: 0 auto; }

h1 { font-size: 2rem; margin-bottom: 0.5rem; }
h2 { font-size: 1.5rem; margin: 2rem 0 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; color: var(--accent); }
h3 { font-size: 1.2rem; margin: 1.5rem 0 0.75rem; color: var(--purple); }
h4 { font-size: 1rem; margin: 1rem 0 0.5rem; color: var(--teal); }

a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }

.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.25rem;
  margin-bottom: 1rem;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
  gap: 1rem;
}

@media (max-width: 900px) {
  .card-grid { grid-template-columns: 1fr; }
}

/* Verdict Banner */
.verdict-banner {
  border: 2px solid var(--green);
  background: linear-gradient(135deg, rgba(63,185,80,0.08), rgba(22,27,34,1));
  padding: 1.5rem;
  border-radius: 10px;
  margin-bottom: 2rem;
}
.verdict-banner h1 { color: var(--green); }
.verdict-banner .subtitle { color: var(--text-muted); font-size: 1.1rem; }

.score-cards {
  display: flex;
  gap: 1rem;
  margin: 1.5rem 0;
  flex-wrap: wrap;
}
.score-card {
  flex: 1;
  min-width: 280px;
  padding: 1.25rem;
  border-radius: 8px;
  text-align: center;
}
.score-card.winner {
  background: rgba(63,185,80,0.1);
  border: 2px solid var(--green);
}
.score-card.loser {
  background: rgba(248,81,73,0.1);
  border: 2px solid var(--red);
}
.score-card .score {
  font-size: 3rem;
  font-weight: 800;
  line-height: 1;
}
.score-card .label {
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-top: 0.25rem;
}
.score-card .branch-name {
  font-size: 1.1rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
  word-break: break-all;
}

/* Badges */
.badge {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 12px;
  font-size: 0.8rem;
  font-weight: 600;
  vertical-align: middle;
}
.badge-green { background: rgba(63,185,80,0.2); color: var(--green); border: 1px solid rgba(63,185,80,0.4); }
.badge-red { background: rgba(248,81,73,0.2); color: var(--red); border: 1px solid rgba(248,81,73,0.4); }
.badge-orange { background: rgba(210,153,34,0.2); color: var(--orange); border: 1px solid rgba(210,153,34,0.4); }
.badge-purple { background: rgba(188,140,255,0.2); color: var(--purple); border: 1px solid rgba(188,140,255,0.4); }
.badge-teal { background: rgba(57,210,192,0.2); color: var(--teal); border: 1px solid rgba(57,210,192,0.4); }

/* Tables */
table {
  width: 100%;
  border-collapse: collapse;
  margin: 1rem 0;
  font-size: 0.9rem;
}
th, td {
  padding: 0.6rem 0.8rem;
  border: 1px solid var(--border);
  text-align: left;
}
th {
  background: var(--surface2);
  color: var(--accent);
  font-weight: 600;
}
td { background: var(--surface); }
tr:hover td { background: var(--surface2); }

/* TOC */
.toc {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.25rem;
  margin-bottom: 2rem;
}
.toc ol { padding-left: 1.5rem; }
.toc li { margin: 0.4rem 0; }

/* Details/Collapsible */
details {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  margin-bottom: 0.75rem;
}
details summary {
  padding: 0.75rem 1rem;
  cursor: pointer;
  font-weight: 600;
  color: var(--accent);
  user-select: none;
}
details summary:hover { background: var(--surface2); border-radius: 8px; }
details[open] summary { border-bottom: 1px solid var(--border); border-radius: 8px 8px 0 0; }
details > div, details > table, details > pre {
  padding: 1rem;
}
details .detail-body { padding: 1rem; }

/* Code blocks */
pre {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 0.75rem 1rem;
  overflow-x: auto;
  font-size: 0.85rem;
  line-height: 1.5;
  margin: 0.5rem 0;
}
code {
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  font-size: 0.85em;
}
:not(pre) > code {
  background: var(--surface2);
  padding: 2px 6px;
  border-radius: 4px;
}

/* Bar charts */
.bar-chart {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin: 1rem 0;
}
.bar-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.bar-label {
  min-width: 240px;
  font-size: 0.85rem;
  text-align: right;
  color: var(--text-muted);
}
.bar-track {
  flex: 1;
  height: 28px;
  background: var(--surface2);
  border-radius: 4px;
  overflow: hidden;
  position: relative;
}
.bar-fill {
  height: 100%;
  border-radius: 4px;
  display: flex;
  align-items: center;
  padding-left: 8px;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--text);
  transition: width 0.5s ease;
}
.bar-fill.green { background: linear-gradient(90deg, rgba(63,185,80,0.6), rgba(63,185,80,0.3)); }
.bar-fill.red { background: linear-gradient(90deg, rgba(248,81,73,0.6), rgba(248,81,73,0.3)); }
.bar-fill.orange { background: linear-gradient(90deg, rgba(210,153,34,0.6), rgba(210,153,34,0.3)); }
.bar-fill.purple { background: linear-gradient(90deg, rgba(188,140,255,0.6), rgba(188,140,255,0.3)); }
.bar-fill.teal { background: linear-gradient(90deg, rgba(57,210,192,0.6), rgba(57,210,192,0.3)); }

/* Progress bar */
.progress-bar {
  width: 100%;
  height: 24px;
  background: var(--surface2);
  border-radius: 4px;
  overflow: hidden;
  display: flex;
  margin: 0.5rem 0;
}
.progress-segment {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  font-weight: 600;
  color: var(--text);
}
.progress-segment.seg-green { background: rgba(63,185,80,0.5); }
.progress-segment.seg-orange { background: rgba(210,153,34,0.5); }
.progress-segment.seg-red { background: rgba(248,81,73,0.5); }

/* Bullets */
ul.verdict-reasons {
  padding-left: 1.5rem;
  margin: 1rem 0;
}
ul.verdict-reasons li {
  margin: 0.4rem 0;
  color: var(--text);
}
ul.verdict-reasons li strong { color: var(--green); }

.winner-text { color: var(--green); font-weight: 700; }
.loser-text { color: var(--red); font-weight: 700; }
.tie-text { color: var(--orange); font-weight: 700; }

.metric-good { color: var(--green); }
.metric-bad { color: var(--red); }
.metric-warn { color: var(--orange); }
.metric-neutral { color: var(--text-muted); }

/* Footer */
footer {
  margin-top: 3rem;
  padding: 1.5rem;
  border-top: 1px solid var(--border);
  color: var(--text-muted);
  font-size: 0.85rem;
  text-align: center;
}
footer a { color: var(--accent); }
</style>
</head>
