<div class="verdict-banner" id="verdict">
  <h1>🏆 Winner: semver/goose/053026-2213</h1>
  <p class="subtitle">PatternFly 5 → 6 Migration Branch Comparison &mdash; Generated 2026-05-30</p>

  <div class="score-cards">
    <div class="score-card winner">
      <div class="branch-name">semver/goose/053026-2213</div>
