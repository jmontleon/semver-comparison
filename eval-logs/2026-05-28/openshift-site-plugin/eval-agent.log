from html.parser import HTMLParser
import sys

class Validator(HTMLParser):
    def __init__(self):
        super().__init__()
        self.errors = []
        self.stack = []
        self.void_elements = {'area','base','br','col','embed','hr','img','input','link','meta','param','source','track','wbr'}
        
    def handle_starttag(self, tag, attrs):
        if tag not in self.void_elements:
            self.stack.append(tag)
            
    def handle_endtag(self, tag):
        if tag in self.void_elements:
            return
        if self.stack and self.stack[-1] == tag:
            self.stack.pop()
        else:
            self.errors.append(f'Mismatched tag: </{tag}> (expected </{self.stack[-1] if self.stack else \"nothing\"}>)')

v = Validator()
with open('pf-migration-comparison-report.html') as f:
    v.feed(f.read())
    
if v.errors:
    print('HTML validation errors:')
    for e in v.errors[:10]:
        print(f'  - {e}')
else:
    print('✅ HTML structure valid')
    
if v.stack:
    print(f'⚠️  Unclosed tags: {v.stack}')
else:
    print('✅ All tags properly closed')
"


