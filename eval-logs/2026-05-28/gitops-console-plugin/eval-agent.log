from html.parser import HTMLParser
import sys

class Validator(HTMLParser):
    def __init__(self):
        super().__init__()
        self.stack = []
        self.errors = []
        self.void_elements = {'area','base','br','col','embed','hr','img','input','link','meta','param','source','track','wbr'}
    
    def handle_starttag(self, tag, attrs):
        if tag not in self.void_elements:
            self.stack.append((tag, self.getpos()))
    
    def handle_endtag(self, tag):
        if tag in self.void_elements:
            return
        if not self.stack:
            self.errors.append(f'Line {self.getpos()[0]}: Unexpected closing tag </{tag}>')
            return
        expected_tag, pos = self.stack.pop()
        if expected_tag != tag:
            self.errors.append(f'Line {self.getpos()[0]}: Expected </{expected_tag}> (opened at line {pos[0]}), got </{tag}>')

with open('pf-migration-comparison-report.html') as f:
    content = f.read()

v = Validator()
v.feed(content)

if v.stack:
    for tag, pos in v.stack:
        print(f'Unclosed tag <{tag}> at line {pos[0]}')

if v.errors:
    for e in v.errors:
        print(e)

if not v.stack and not v.errors:
    print('HTML validation: OK - no unclosed or mismatched tags found')
print(f'Total lines: {len(content.splitlines())}')
"


