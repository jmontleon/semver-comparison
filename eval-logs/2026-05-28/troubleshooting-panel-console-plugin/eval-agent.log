    content: <!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PatternFly 5→6 Migration Comparison Report</title>
<style>
:root {
  --bg: #0d1117;
  --surface: #161b22;
  --surface2: #1c2129;
  --border: #30363d;
  --text: #e6edf3;
  --text-muted: #8b949e;
  --accent: #58a6ff;
  --green: #3fb950;
  --red: #f85149;
  --orange: #d29922;
  --purple: #bc8cff;
  --teal: #39d2c0;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  padding: 2rem 1rem;
}
.container { max-width: 1400px; margin: 0 auto; }
h1 { font-size: 2rem; margin-bottom: 0.5rem; }
h2 { font-size: 1.5rem; margin: 2rem 0 1rem; color: var(--accent); border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
h3 { font-size: 1.2rem; margin: 1.5rem 0 0.75rem; color: var(--text); }
h4 { font-size: 1rem; margin: 1rem 0 0.5rem; color: var(--text-muted); }
a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }
p { margin: 0.5rem 0; }
ul, ol { margin: 0.5rem 0 0.5rem 1.5rem; }
li { margin: 0.25rem 0; }
code {
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  background: var(--surface2);
  padding: 0.15em 0.4em;
  border-radius: 4px;
  font-size: 0.9em;
}
pre {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1rem;
  overflow-x: auto;
  font-size: 0.85rem;
  line-height: 1.5;
  margin: 0.75rem 0;
}
pre code { background: none; padding: 0; }
table {
  width: 100%;
  border-collapse: collapse;
  margin: 1rem 0;
  font-size: 0.9rem;
}
th, td {
  padding: 0.6rem 0.8rem;
  border: 1px solid var(--border);
  text-align: left;
  vertical-align: top;
}
th { background: var(--surface2); font-weight: 600; color: var(--text); }
td { background: var(--surface); }
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.5rem;
  margin: 1rem 0;
}
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
  gap: 1rem;
  margin: 1rem 0;
}
@media (max-width: 900px) {
  .card-grid { grid-template-columns: 1fr; }
}
.verdict-banner {
  border: 2px solid var(--green);
  background: linear-gradient(135deg, rgba(63,185,80,0.08), rgba(63,185,80,0.02));
}
.badge {
  display: inline-block;
  padding: 0.15em 0.6em;
  border-radius: 12px;
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}
.badge-green { background: rgba(63,185,80,0.2); color: var(--green); }
.badge-red { background: rgba(248,81,73,0.2); color: var(--red); }
.badge-orange { background: rgba(210,153,34,0.2); color: var(--orange); }
.badge-purple { background: rgba(188,140,255,0.2); color: var(--purple); }
.badge-teal { background: rgba(57,210,192,0.2); color: var(--teal); }
.badge-muted { background: rgba(139,148,158,0.2); color: var(--text-muted); }
.score-card {
  text-align: center;
  padding: 1.25rem;
}
.score-card .score-value {
  font-size: 2.5rem;
  font-weight: 700;
  line-height: 1;
}
.score-card .score-label {
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-top: 0.3rem;
}
.score-card.winner { border-color: var(--green); }
.score-card.winner .score-value { color: var(--green); }
.score-card.loser { border-color: var(--red); }
.score-card.loser .score-value { color: var(--red); }
.bar-chart {
  margin: 1rem 0;
}
.bar-row {
  display: flex;
  align-items: center;
  margin: 0.5rem 0;
  gap: 0.75rem;
}
.bar-label {
  min-width: 220px;
  font-size: 0.85rem;
  text-align: right;
  color: var(--text-muted);
}
.bar-track {
  flex: 1;
  height: 24px;
  background: var(--surface2);
  border-radius: 4px;
  overflow: hidden;
  position: relative;
}
.bar-fill {
  height: 100%;
  border-radius: 4px;
  display: flex;
  align-items: center;
  padding-left: 8px;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--bg);
  min-width: fit-content;
  transition: width 0.5s ease;
}
.bar-green { background: var(--green); }
.bar-red { background: var(--red); }
.bar-orange { background: var(--orange); }
.bar-purple { background: var(--purple); }
.bar-teal { background: var(--teal); }
.progress-bar {
  width: 100%;
  height: 28px;
  background: var(--surface2);
  border-radius: 6px;
  overflow: hidden;
  display: flex;
  margin: 0.5rem 0;
}
.progress-segment {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  font-weight: 600;
  color: var(--bg);
}
details {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  margin: 0.75rem 0;
  overflow: hidden;
}
details[open] { border-color: var(--accent); }
summary {
  padding: 0.8rem 1rem;
  cursor: pointer;
  font-weight: 600;
  color: var(--text);
  background: var(--surface2);
  list-style: none;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
summary::-webkit-details-marker { display: none; }
summary::before {
  content: '▸';
  display: inline-block;
  transition: transform 0.2s;
  color: var(--text-muted);
}
details[open] > summary::before { transform: rotate(90deg); }
details .detail-content { padding: 1rem; }
.metric-good { color: var(--green); }
.metric-bad { color: var(--red); }
.metric-warn { color: var(--orange); }
.metric-neutral { color: var(--text-muted); }
.winner-tag {
  display: inline-block;
  background: rgba(63,185,80,0.15);
  color: var(--green);
  border: 1px solid var(--green);
  padding: 0.1em 0.5em;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 700;
  margin-left: 0.5rem;
}
.loser-tag {
  display: inline-block;
  background: rgba(248,81,73,0.15);
  color: var(--red);
  border: 1px solid var(--red);
  padding: 0.1em 0.5em;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 700;
  margin-left: 0.5rem;
}
.tie-tag {
  display: inline-block;
  background: rgba(210,153,34,0.15);
  color: var(--orange);
  border: 1px solid var(--orange);
  padding: 0.1em 0.5em;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 700;
  margin-left: 0.5rem;
}
