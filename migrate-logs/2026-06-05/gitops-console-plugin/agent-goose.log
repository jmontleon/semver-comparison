    /** The max width of the label before it is truncated. Can be any valid CSS unit, such as '100%', '100px', or '16ch'. */
    textMaxWidth?: string;
    /** Position of the tooltip which is displayed if text is truncated */In PF6, `isTruncated` was replaced with `textMaxWidth`. To maintain truncation behavior, I'll simply remove `isTruncated` since the Label will still truncate based on its container. Alternatively, I could set a `textMaxWidth` value, but the simplest fix that preserves behavior is to just remove the prop.
