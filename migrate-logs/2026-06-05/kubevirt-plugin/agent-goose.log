import React, { Ref } from 'react';

import { MenuToggle, MenuToggleElement, MenuToggleProps } from '@patternfly/react-core';

type SelectToggleProps = MenuToggleProps & {
  'data-test-id'?: string;
  selected: any;
};

const SelectToggle = ({
  'data-test-id': dataTestID,
  selected,
  ...menuProps
}: SelectToggleProps) => {
  return (toggleRef: Ref<MenuToggleElement>) => (
    <MenuToggle data-test-id={dataTestID} ref={toggleRef} {...menuProps}>
      {menuProps.children ?? selected}
    </MenuToggle>
  );
};

export default SelectToggle;I see - `SelectToggle` extends `MenuToggleProps`. The `placeholder` was being spread as part of `menuProps` into `MenuToggle`, which doesn't accept it. In PF6, `MenuToggleProps` doesn't have `placeholder` but has `isPlaceholder`.

The cleanest fix is to extend the `toggleProps` type in `InlineFilterSelect` to include `placeholder` as a custom field, and handle it properly. Let me also check how `FormPFSelect` uses `toggleProps`:
  ────────────────────────────────────────
  ▸ shell
    command: cd /home/jmontleo/semver-analyzer/build/batch-run-20260608T145537/kubevirt-plugin/source && cat src/utils/components/FormPFSelect/FormPFSelect.tsx

import React, { FC, useState } from 'react';

import { MenuToggleProps, Select, SelectProps } from '@patternfly/react-core';

import SelectToggle from '../toggles/SelectToggle';

type FormPFSelectProps = Omit<SelectProps, 'isOpen' | 'toggle'> & {
  closeOnSelect?: boolean;
  selectedLabel?: any;
  toggleProps?: MenuToggleProps;
};

const FormPFSelect: FC<FormPFSelectProps> = ({
  children,
  className,
  closeOnSelect = true,
  onSelect,
  selected,
  selectedLabel,
  toggleProps,
  ...props
}) => {
  const [isOpen, setIsOpen] = useState(false);

  const onToggle = () => setIsOpen((prevIsOpen) => !prevIsOpen);

  return (
    <Select
      onSelect={(event, value) => {
        onSelect && onSelect(event, value);
        closeOnSelect && setIsOpen(false);
      }}
      toggle={SelectToggle({
        isExpanded: isOpen,
        onClick: onToggle,
        selected: selectedLabel || selected || toggleProps?.placeholder,
        ...toggleProps,
      })}
      className={className}
      isOpen={isOpen}
      isScrollable
      onOpenChange={(open: boolean) => setIsOpen(open)}
      selected={selected}
      {...props}
    >
      {children}
    </Select>
  );
};

