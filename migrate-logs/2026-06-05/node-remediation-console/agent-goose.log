    content: // eslint-disable-next-line no-restricted-imports
import { useTranslation } from "react-i18next";

// TFunction type that always returns string, compatible with ReactNode in React 18.
// This is needed because i18next's TFunction returns TFunctionResult which includes
// 'object', and React 18's stricter types don't allow 'object' as ReactNode.
export type TFunction = (
  key: string | string[],
  options?: string | Record<string, unknown>,
  options2?: Record<string, unknown>
) => string;

export const useNodeHealthCheckTranslation = () => {
  const { t, ...rest } = useTranslation(
    "plugin__node-remediation-console-plugin"
  );
  return { t: t as unknown as TFunction, ...rest };
};


