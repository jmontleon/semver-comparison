  );
  return React.Children.toArray(children).length ? (
    <PopoverStatus
      title={popoverTitle || title}
      {...restProps}
      statusBody={statusBody}
    >
      {children}
    </PopoverStatus>
  ) : (
    statusBody
  );
};

