        kmsStateClone[id].fileName = filename;
        updateKmsState(kmsStateClone);
      };
      reader.onerror = () => {
        kmsStateClone[id].fileName = filename;
        setError(FileReadErrorMsg);
      };
      if (file) {
        reader.readAsText(file, 'UTF-8');
      } else {
        kmsStateClone[id].value = '';
        kmsStateClone[id].error = '';
        kmsStateClone[id].fileName = '';
