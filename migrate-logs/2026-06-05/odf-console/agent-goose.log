} from '@patternfly/react-core';
import './modal.scss';

export type CommonModalProps<T = {}> = {
  isOpen: boolean;
  closeModal: () => void;
  extraProps: T;
};

export const ModalBody: React.FC<ModalBodyProps> = ({
  children,
  className,
  ...props
}) => (
  <PFModalBody
    className={classNames('modal--padding', 'modal--overflow', className)}
    {...props}
  >
    {children}
  </PFModalBody>
);

type ModalHeaderProps = {
  className?: string;
};

export const ModalHeader: React.FC<ModalHeaderProps> = ({
  children,
  className,
}) => (
  <Title headingLevel="h1" size={TitleSizes['2xl']} className={className}>
    {children}
  </Title>
);

export const ModalFooter: React.FC<ModalFooterProps> = ({
  children,
  className,
  ...props
}) => (
  <PFModalFooter
    className={classNames('modalFooter--justifyEnd', className)}
    {...props}
  >
    {children}
  </PFModalFooter>
);


