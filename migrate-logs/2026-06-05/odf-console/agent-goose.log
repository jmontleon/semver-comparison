    // Workaround: webpack 5.99 does not apply module.rules loaders to
    // ModuleFederationPlugin container-entry exposed modules.  Inject the
    // required loaders via the beforeLoaders hook so every source file in
    // packages/ is processed by ts-loader (for TS/TSX) or the SCSS pipeline.
    {
      apply(compiler: webpack.Compiler) {
        compiler.hooks.thisCompilation.tap('InjectMissingLoaders', (compilation) => {
          webpack.NormalModule.getCompilationHooks(compilation).beforeLoaders.tap(
            'InjectMissingLoaders',
            (loaders: any[], normalModule: any) => {
              const resource: string = normalModule.resource || '';
              const inPackages = resource.includes('packages');
              const inOdfModules = resource.includes('node_modules/@odf');
              const inConsoleSDK = resource.includes('node_modules/@openshift-console');
              if (!inPackages && !inOdfModules && !inConsoleSDK) return;

              const hasLoader = (name: string) =>
                loaders.some((l: any) => l.loader && l.loader.includes(name));

              // Inject ts-loader for TypeScript / JavaScript files
              if (/\.(tsx?|jsx?)$/.test(resource) && !hasLoader('ts-loader')) {
                loaders.unshift({
                  loader: require.resolve('ts-loader'),
                  options: {
                    configFile: path.resolve(__dirname, 'tsconfig.json'),
                    transpileOnly: true,
                    happyPackMode: true,
                  },
                  ident: undefined,
                  type: undefined,
                });
              }

              // Inject SCSS loader chain
              if (/\.scss$/.test(resource) && !hasLoader('sass-loader')) {
                const scssLoaders = [
                  { loader: MiniCssExtractPlugin.loader, options: undefined, ident: undefined, type: undefined },
                  { loader: require.resolve('css-loader'), options: { sourceMap: true }, ident: undefined, type: undefined },
                  {
                    loader: require.resolve('resolve-url-loader'),
                    options: { sourceMap: true },
                    ident: undefined,
                    type: undefined,
                  },
                  {
                    loader: require.resolve('sass-loader'),
                    options: { sassOptions: { style: 'compressed', quietDeps: true, loadPaths: [path.resolve(__dirname, 'node_modules')] }, sourceMap: true },
                    ident: undefined,
                    type: undefined,
                  },
                ];
                loaders.unshift(...scssLoaders);
              }
            },
          );
        });
      },
    },

