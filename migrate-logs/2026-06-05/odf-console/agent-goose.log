      },
      {
        title: t('Type'),
        sort: 'type',
        transforms: [sortable],
        props: { className: tableColumnClasses[2].className },
        id: tableColumnClasses[2].id,
      },
      {
        title: t('Model'),
        sort: 'model',
        transforms: [sortable],
        props: { className: tableColumnClasses[3].className },
        id: tableColumnClasses[3].id,
      },
      {
        title: t('Capacity'),
        sort: 'size',
        transforms: [sortable],
