    # Replace multi-line patterns like:
    # screen.getByRole('dialog', {
    #   description: /text/i,
    # })
    # with: screen.getByText(/text/i)
    pattern = r"screen\.getByRole\('dialog',\s*\{\s*description:\s*(\/[^\/]+\/[a-z]*),?\s*\}\)"
    replacement = r"screen.getByText(\1)"
