  <TProps extends {}>(
    Component: React.ComponentClass<TProps> | React.FC<TProps>,
  ) =>
  (props: TProps) => {
    return (
      <DndProvider backend={HTML5Backend} context={window}>
        <Component {...props} />
      </DndProvider>
    );
  };

